generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String
  phone         String?
  city          String?
  country       String?
  emailVerified DateTime?
  image         String?
  bio           String?   @db.Text
  language      String    @default("en")
  currency      String    @default("USD")
  travelStyle   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts      Account[]
  sessions     Session[]
  trips        Trip[]
  activities   Activity[]
  notes        Note[]
  packingItems PackingItem[]
  budgets      Budget[]
  expenses     Expense[]
  savedDestinations SavedDestination[]
  preferences  UserPreferences?
  tripLikes    TripLike[]
  tripBookmarks TripBookmark[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Destination/City Database
model Destination {
  id            String   @id @default(cuid())
  name          String   @unique
  country       String
  region        String
  description   String?  @db.Text
  imageUrl      String?
  dailyBudget   Float?
  popularity    Int      @default(0)
  rating        Float    @default(0)
  climate       String?
  travelType   String?
  tags          String[]
  isPopular     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  savedBy   SavedDestination[]
}

model SavedDestination {
  id            String   @id @default(cuid())
  userId        String
  destinationId String
  createdAt     DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  destination Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  @@unique([userId, destinationId])
}

// Activity Categories
model ActivityCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  icon        String?
  description String?

  activities Activity[]
}

// Activity Database
model Activity {
  id            String   @id @default(cuid())
  name          String   @unique
  description   String?  @db.Text
  location      String?
  imageUrl      String?
  duration      String?
  cost          Float?
  currency      String   @default("USD")
  rating        Float    @default(0)
  categoryId    String?
  category      ActivityCategory? @relation(fields: [categoryId], references: [id])

  // Activity properties
  isIndoor     Boolean?
  isFamilyFriendly Boolean?
  adventureLevel String? // easy, moderate, challenging

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  userId       String?
  user         User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  tripId       String?
  trip         Trip?   @relation(fields: [tripId], references: [id], onDelete: SetNull)
  cityId       String?
  city         City?   @relation(fields: [cityId], references: [id], onDelete: SetNull)
}

// Trip Itinerary Models
model Trip {
  id          String   @id @default(cuid())
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime
  coverImage  String?
  isPublic    Boolean  @default(false)
  shareId     String?  @unique
  travelType  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cities      City[]
  activities  Activity[]
  notes       Note[]
  packingItems PackingItem[]
  budgets     Budget[]
  likes       TripLike[]
  bookmarks   TripBookmark[]
}

model City {
  id          String   @id @default(cuid())
  name        String
  country     String
  startDate   DateTime
  endDate     DateTime
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  tripId      String
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  activities  Activity[]
  notes       Note[]
}

model Note {
  id          String   @id @default(cuid())
  title       String
  content     String   @db.Text
  category    String   @default("general") // hotel, transport, food, emergency, reminder, journal, general
  priority    String   @default("medium") // low, medium, high
  tags        String[]
  isArchived  Boolean  @default(false)
  isJournal   Boolean  @default(false)
  mood        String?  // happy, excited, relaxed, tired, adventurous
  tripId      String?
  cityId      String?
  noteDate    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip        Trip?    @relation(fields: [tripId], references: [id], onDelete: Cascade)
  city        City?    @relation(fields: [cityId], references: [id], onDelete: SetNull)
}

model PackingItem {
  id          String   @id @default(cuid())
  name        String
  quantity    Int      @default(1)
  category    String   @default("general")
  notes       String?
  priority    String   @default("medium") // low, medium, high
  isPacked    Boolean  @default(false)
  isEssential Boolean  @default(false)
  tripId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model Budget {
  id          String   @id @default(cuid())
  name        String
  totalAmount Float
  currency    String   @default("USD")
  tripId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  expenses    Expense[]
}

model Expense {
  id          String   @id @default(cuid())
  description String
  amount      Float
  category    String?
  date        DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  budgetId    String
  budget      Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserPreferences {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailNotifications  Boolean  @default(true)
  pushNotifications   Boolean  @default(true)
  tripReminders       Boolean  @default(true)
  marketingEmails     Boolean  @default(false)
  theme               String   @default("dark")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// Community Features
model TripLike {
  id        String   @id @default(cuid())
  userId    String
  tripId    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([userId, tripId])
}

model TripBookmark {
  id        String   @id @default(cuid())
  userId    String
  tripId    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([userId, tripId])
}